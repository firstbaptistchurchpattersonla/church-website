---
---

<footer class="bg-navy text-cream">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <div>
        <h3 class="font-serif text-xl font-semibold text-cream mb-1">First Baptist Church</h3>
        <p class="font-sans text-[10px] font-medium tracking-[0.25em] uppercase text-gold mb-5">Patterson, Louisiana</p>
        <p class="font-serif text-cream/60 text-sm leading-relaxed italic">
          "Loving God and People"
        </p>
      </div>

      <div>
        <h4 class="font-sans text-[10px] font-semibold tracking-[0.25em] uppercase text-gold mb-5">Service Times</h4>
        <ul class="space-y-3 font-sans text-sm text-cream/75">
          <li>
            <span class="block text-cream font-medium mb-0.5">Sunday</span>
            <span class="block">9:30 AM — Sunday School</span>
            <span class="block">10:30 AM — Worship Service</span>
          </li>
          <li class="pt-1">
            <span class="block text-cream font-medium mb-0.5">Wednesday</span>
            <span class="block">6:00 PM — Bible Study</span>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-sans text-[10px] font-semibold tracking-[0.25em] uppercase text-gold mb-5">Find Us</h4>
        <ul class="space-y-3 font-sans text-sm text-cream/75">
          <li class="leading-relaxed">
            1621 Main Street<br />
            Patterson, LA 70392
          </li>
          <li>
            <a href="tel:9853953681" class="hover:text-gold transition-colors duration-200">(985) 395-3681</a>
          </li>
          <li>
            <a
              href="mailto:firstbaptistchurchpattersonla@gmail.com"
              class="hover:text-gold transition-colors duration-200 break-all"
            >
              firstbaptistchurchpattersonla@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-cream/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-sans text-xs text-cream/35">
        © {new Date().getFullYear()} First Baptist Church Patterson, LA. All rights reserved.
      </p>
      <nav class="flex flex-wrap gap-6">
        {['/', '/about', '/calendar', '/newsletter', '/contact'].map((href, i) => (
          <a
            href={href}
            class="font-sans text-xs text-cream/35 hover:text-gold transition-colors duration-200"
          >
            {['Home', 'About', 'Calendar', 'Newsletter', 'Contact'][i]}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
