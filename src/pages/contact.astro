---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — First Baptist Church Patterson, LA"
  description="Get in touch with First Baptist Church in Patterson, LA. We'd love to hear from you."
>
  <section class="py-32 bg-cream min-h-[calc(100vh-5rem)]">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-20">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="h-px w-10 bg-gold/40"></div>
          <span class="font-sans text-[10px] font-semibold tracking-[0.3em] uppercase text-gold">Get in Touch</span>
          <div class="h-px w-10 bg-gold/40"></div>
        </div>
        <h1 class="font-serif text-5xl md:text-6xl font-semibold text-navy mt-2 mb-4">Contact Us</h1>
        <p class="font-sans text-lg text-slate-500">We'd love to hear from you.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 max-w-3xl mx-auto">

        <div>
          <h2 class="font-serif text-2xl font-semibold text-navy mb-6">Visit Us</h2>
          <p class="font-sans text-slate-600 leading-relaxed mb-1">1621 Main Street</p>
          <p class="font-sans text-slate-600 leading-relaxed mb-6">Patterson, LA 70392</p>
          <a href="tel:9853953681" class="font-sans text-gold font-medium hover:text-navy transition-colors duration-200">
            (985) 395-3681
          </a>

          <div class="mt-10">
            <h3 class="font-sans text-[10px] font-semibold tracking-[0.25em] uppercase text-gold mb-4">Service Times</h3>
            <ul class="space-y-2 font-sans text-sm text-slate-600">
              <li>Sunday 9:30 AM — Sunday School</li>
              <li>Sunday 10:30 AM — Worship Service</li>
              <li>Wednesday 6:00 PM — Bible Study</li>
            </ul>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-navy mb-6">Send Us a Message</h2>
          <p class="font-sans text-slate-600 leading-relaxed mb-8">
            Have a question, a prayer request, or want to learn more about our church?
            We'd love to connect with you.
          </p>
          <a
            href="mailto:firstbaptistchurchpattersonla@gmail.com"
            class="inline-flex items-center gap-2 px-8 py-4 bg-navy text-cream font-sans font-semibold text-sm tracking-wide rounded transition-all duration-200 hover:bg-gold hover:text-navy"
          >
            Contact Us
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>
</Layout>
