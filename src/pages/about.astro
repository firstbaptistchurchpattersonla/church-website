---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About | First Baptist Church Patterson, LA"
  description="Learn about First Baptist Church in Patterson, Louisiana. Our history, mission, and community."
>
  <section class="py-32 bg-cream min-h-[calc(100vh-5rem)]">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="h-px w-10 bg-gold/40"></div>
        <span class="font-sans text-[10px] font-semibold tracking-[0.3em] uppercase text-gold">Our Story</span>
        <div class="h-px w-10 bg-gold/40"></div>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold text-navy mt-2 mb-8">About Our Church</h1>
      <p class="font-sans text-lg text-slate-600 leading-relaxed">
        Content coming soon. We are a small, traditional Baptist church in Patterson, Louisiana,
        planted by the hand of God in St. Mary Parish for Kingdom work and committed to
        loving God and loving people.
      </p>
    </div>
  </section>
</Layout>
