---
import Layout from '../layouts/Layout.astro';

const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSYqnkwYunel9o-lH5NZ9fuFANJHx5CdYtXEDTlHJb3kbrpvzOuAPZHKFhJ6jdWl4aV3ciFwIdBomKs/pub?gid=0&single=true&output=csv';
---

<Layout
  title="Mission Outreach | First Baptist Church Patterson, LA"
  description="First Baptist Church Patterson reaches out to those in need in St. Mary Parish through donated items and financial assistance. See what we currently need."
>

  <!-- ░░ HERO ░░ -->
  <section class="py-28 bg-navy">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="h-px w-10 bg-gold/40"></div>
        <span class="font-sans text-[10px] font-semibold tracking-[0.3em] uppercase text-gold">Serving Our Community</span>
        <div class="h-px w-10 bg-gold/40"></div>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold text-cream mt-2 mb-6">Mission Outreach</h1>
      <p class="font-serif text-xl text-cream/70 italic">
        Being the hands and feet of Jesus in St. Mary Parish
      </p>
    </div>
  </section>

  <!-- ░░ BLURB ░░ -->
  <section class="py-20 bg-cream">
    <div class="max-w-2xl mx-auto px-6">
      <div class="flex items-center gap-4 mb-8">
        <div class="h-px w-10 bg-gold/40"></div>
        <span class="font-sans text-[10px] font-semibold tracking-[0.3em] uppercase text-gold">Our Mission</span>
      </div>
      <div class="space-y-6 font-sans text-lg text-slate-600 leading-relaxed">
        <p>
          At First Baptist Church Patterson, we believe that faith without action is faith
          left unfinished. Our Mission Outreach program is how we put that belief into practice.
          Through donated goods and financial assistance, we serve the people of Patterson and
          the surrounding St. Mary Parish who are facing hardship.
        </p>
        <p>
          The needs of our community change regularly, and so does our list of needed items.
          We keep this page updated so you always know exactly how you can help right now.
          Every donation, large or small, makes a real difference in the life of someone in our community.
        </p>
        <p>
          If you feel led to give, bring your donation to the church during any service or
          call us at <a href="tel:9853953681" class="text-gold hover:text-navy transition-colors font-medium">(985) 395-3681</a> to arrange a drop-off.
          Thank you for partnering with us in this work.
        </p>
      </div>
    </div>
  </section>

  <!-- ░░ NEEDED ITEMS ░░ -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="h-px w-10 bg-gold/40"></div>
          <span class="font-sans text-[10px] font-semibold tracking-[0.3em] uppercase text-gold">How You Can Help</span>
          <div class="h-px w-10 bg-gold/40"></div>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-navy mt-2 mb-3">Currently Needed</h2>
        <p class="font-sans text-slate-500 text-sm">Updated regularly. Check back often.</p>
      </div>

      <div id="outreach-items">
        <div class="flex justify-center py-12">
          <div class="w-8 h-8 border-2 border-gold border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script define:vars={{ CSV_URL }}>
  const PRIORITY_ORDER = { high: 0, medium: 1, low: 2 };
  const PRIORITY_STYLES = {
    high:    { label: 'High Priority',   border: 'border-red-400',  badge: 'bg-red-50 text-red-600' },
    medium:  { label: 'Medium Priority', border: 'border-gold',     badge: 'bg-amber-50 text-amber-700' },
    low:     { label: 'Low Priority',    border: 'border-navy/20',  badge: 'bg-slate-100 text-slate-500' },
    default: { label: 'Needed',          border: 'border-navy/20',  badge: 'bg-slate-100 text-slate-500' },
  };

  function parseCSV(text) {
    return text.split('\n').map(line => {
      const result = [];
      let cell = '', inQuotes = false;
      for (const ch of line) {
        if (ch === '"') { inQuotes = !inQuotes; }
        else if (ch === ',' && !inQuotes) { result.push(cell.trim()); cell = ''; }
        else { cell += ch; }
      }
      result.push(cell.trim());
      return result;
    }).filter(row => row.some(c => c.trim()));
  }

  function renderCard(item, category, notes, priorityKey) {
    const style = PRIORITY_STYLES[priorityKey] ?? PRIORITY_STYLES.default;
    return `
      <div class="bg-cream rounded-xl p-6 border-l-4 ${style.border} shadow-sm">
        <div class="flex items-start justify-between gap-3 mb-1">
          <p class="font-serif text-lg font-semibold text-navy leading-snug">${item}</p>
          ${category ? `<span class="flex-shrink-0 font-sans text-[10px] font-semibold tracking-wider uppercase px-2 py-1 rounded ${style.badge}">${category}</span>` : ''}
        </div>
        ${notes ? `<p class="font-sans text-sm text-slate-500 mt-2 leading-relaxed">${notes}</p>` : ''}
      </div>
    `;
  }

  async function loadItems() {
    const container = document.getElementById('outreach-items');
    if (!container) return;

    try {
      const response = await fetch(CSV_URL);
      const text = await response.text();
      const rows = parseCSV(text);

      if (rows.length < 2) {
        container.innerHTML = '<p class="text-center font-sans text-slate-400 py-8">No items currently listed. Check back soon.</p>';
        return;
      }

      const headers = rows[0].map(h => h.trim().toLowerCase());
      const data = rows.slice(1).filter(row => row.some(c => c.trim()));

      const idxItem  = headers.findIndex(h => h.includes('item') || h.includes('name'));
      const idxPri   = headers.findIndex(h => h.includes('prior'));
      const idxCat   = headers.findIndex(h => h.includes('cat'));
      const idxNotes = headers.findIndex(h => h.includes('note') || h.includes('desc'));

      const getField = (row, idx) => idx >= 0 ? (row[idx] || '').trim() : '';

      // Sort by priority then category
      const sorted = [...data].sort((a, b) => {
        const pa = PRIORITY_ORDER[getField(a, idxPri).toLowerCase()] ?? 99;
        const pb = PRIORITY_ORDER[getField(b, idxPri).toLowerCase()] ?? 99;
        if (pa !== pb) return pa - pb;
        return getField(a, idxCat).localeCompare(getField(b, idxCat));
      });

      // Group by priority
      const groups = {};
      sorted.forEach(row => {
        const priRaw = getField(row, idxPri).toLowerCase();
        const priKey = PRIORITY_ORDER[priRaw] !== undefined ? priRaw : 'default';
        if (!groups[priKey]) groups[priKey] = [];
        groups[priKey].push(row);
      });

      container.innerHTML = Object.entries(groups).map(([priKey, rows]) => {
        const style = PRIORITY_STYLES[priKey] ?? PRIORITY_STYLES.default;
        return `
          <div class="mb-12">
            <div class="flex items-center gap-4 mb-6">
              <h3 class="font-sans text-xs font-semibold tracking-[0.25em] uppercase text-navy/60">${style.label}</h3>
              <div class="flex-1 h-px bg-navy/10"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              ${rows.map(row => renderCard(
                getField(row, idxItem) || row[0],
                getField(row, idxCat),
                getField(row, idxNotes),
                priKey
              )).join('')}
            </div>
          </div>
        `;
      }).join('');

    } catch {
      container.innerHTML = '<p class="text-center font-sans text-slate-400 py-8">Unable to load items right now. Please check back soon or call us at (985) 395-3681.</p>';
    }
  }

  loadItems();
</script>
